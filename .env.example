# wx-assist-demo 配置文件
# 复制此文件为 .env 并填入你的 AI 配置

# === AI 后端选择 ===
# "claude" 或 "deepseek"（legacy 模式）
AI_BACKEND=deepseek

# === 新统一 AI Provider 配置（推荐）===
# 填写后优先于 legacy 模式
# 支持任何 OpenAI 兼容 API（DeepSeek、OpenAI、Ollama 等）
AI_PROVIDER_BASE_URL=https://api.deepseek.com
AI_PROVIDER_API_KEY=your-api-key-here
AI_PROVIDER_TYPE=auto
AI_PROVIDER_MODEL=deepseek-v4-flash

# === DeepSeek 配置（legacy）===
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# === Claude 配置（legacy）===
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
SUMMARIZE_MODEL=claude-haiku-4-5-20251001

# === 机器人设置 ===
BOT_DISPLAY_NAME=群聊小助手

# === 日志 ===
LOG_LEVEL=INFO
LOG_FILE=data/demo.log

# === 引导完成标记 ===
ONBOARDING_DONE=false
